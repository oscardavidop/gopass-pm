{
  "name": "@gopass/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run clean && nest build",
    "dev": "nest start --watch",
    "prebuild": "npm run prisma:generate",
    "pretypecheck": "npm run prisma:generate",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "start": "node dist/main.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:restart": "pm2 restart ecosystem.config.js --update-env --env production",
    "pm2:stop": "pm2 stop gopass-api",
    "pm2:delete": "pm2 delete gopass-api",
    "pm2:logs": "pm2 logs gopass-api",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status",
    "docker:build": "docker compose -f docker-compose.prod.yml build api",
    "docker:start": "docker compose -f docker-compose.prod.yml up -d postgres redis api",
    "docker:stop": "docker compose -f docker-compose.prod.yml down",
    "deploy": "bash ./scripts/deploy-api.sh",
    "update:prod": "bash ./scripts/update-api.sh",
    "storage:migrate-local-to-s3": "ts-node scripts/migrate-local-files-to-s3.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:seed": "prisma generate && ts-node prisma/seed.ts",
    "prisma:reset": "prisma migrate reset --force && ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1058.0",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.24",
    "@prisma/client": "^5.22.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@zavudev/sdk": "^0.43.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.6",
    "file-type": "^21.3.4",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "is-svg": "^6.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "pm2": "^7.0.1",
    "pm2-runtime": "^5.4.1",
    "readmeio": "^6.2.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.2",
    "socket.io": "^4.7.5",
    "uuid": "^14.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.14.10",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "prisma": "^5.14.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20 <26"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
