NODE_ENV=development

# PostgreSQL
DATABASE_URL="postgresql://gopass:gopass_secret@localhost:5432/gopass_pm?schema=public"

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=dev_access_secret_change_in_production_32chars
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production_32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
API_PORT=3001
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Logger
LOG_LEVEL=debug
