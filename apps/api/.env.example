NODE_ENV=development

# PostgreSQL
DATABASE_URL="postgresql://gopass:gopass_secret@localhost:5432/gopass_pm?schema=public"

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=dev_access_secret_change_in_production_32chars
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production_32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
API_PORT=3001
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# Email
SEND_REAL_EMAIL=false
ZAVU_API_KEY=
ZAVU_SENDER_ID=
ZAVU_TEMPLATE_RESET_PASSWORD=
ZAVU_TEMPLATE_RESET_PASSWORD_ES=
ZAVU_TEMPLATE_RESET_PASSWORD_EN=
ZAVU_TEMPLATE_WELCOME=
ZAVU_TEMPLATE_WELCOME_ES=
ZAVU_TEMPLATE_WELCOME_EN=
ZAVU_TEMPLATE_PROJECT_INVITATION=
ZAVU_TEMPLATE_PROJECT_INVITATION_ES=
ZAVU_TEMPLATE_PROJECT_INVITATION_EN=
ZAVU_TEMPLATE_TASK_ASSIGNED=
ZAVU_TEMPLATE_TASK_ASSIGNED_ES=
ZAVU_TEMPLATE_TASK_ASSIGNED_EN=
ZAVU_TEMPLATE_TASK_DUE_REMINDER=
ZAVU_TEMPLATE_TASK_DUE_REMINDER_ES=
ZAVU_TEMPLATE_TASK_DUE_REMINDER_EN=
ZAVU_TEMPLATE_WEEKLY_DIGEST=
ZAVU_TEMPLATE_WEEKLY_DIGEST_ES=
ZAVU_TEMPLATE_WEEKLY_DIGEST_EN=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Logger
LOG_LEVEL=debug

# Cloudflare Workers AI
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.1-8b-instruct
AI_REQUEST_TIMEOUT_MS=18000
AI_REQUEST_RETRIES=2
AI_CACHE_TTL_MS=90000
